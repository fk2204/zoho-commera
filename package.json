{
  "name": "zoho-claude",
  "version": "0.2.0",
  "description": "Programmatic control of Zoho One via Claude Code",
  "type": "module",
  "private": true,
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "setup:oauth": "node scripts/setup-oauth.js",
    "test:connection": "node scripts/test-connection.js",
    "refresh-token": "node scripts/refresh-token.js",
    "run": "node scripts/automation/run-all.js",
    "run:dry": "cross-env DRY_RUN=true node scripts/automation/run-all.js",
    "scheduler": "node scripts/automation/scheduler.js",
    "match-lenders": "node -e \"import('./scripts/automation/jobs/match-lenders.js').then(m => m.run())\""
  },
  "dependencies": {
    "dotenv": "^16.4.5",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0"
  }
}
