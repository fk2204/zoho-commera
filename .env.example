# =============================================================================
# Zoho Self Client credentials (from https://api-console.zoho.com)
# Required for ALL apps.
# =============================================================================
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=

# =============================================================================
# Per-app organization IDs.
# These are DIFFERENT for each app (Books has its own, Inventory has its own,
# etc.). Fill in only the ones you'll use.
#
# Where to find each:
#   Books:     Settings → Organizations  (or https://books.zoho.com — URL contains it)
#   Inventory: Settings → Organizations
#   Desk:      Setup → API → "Organization ID"
#   Projects:  URL contains the portal_id, or Setup → API
#
# Other apps (Cliq, Mail, Sign, WorkDrive, People, Campaigns) don't need an
# org ID — they infer context from the user token.
# =============================================================================
ZOHO_BOOKS_ORG_ID=
ZOHO_INVENTORY_ORG_ID=
ZOHO_DESK_ORG_ID=
ZOHO_PROJECTS_PORTAL_ID=

# =============================================================================
# Email sending via Zoho Mail SMTP
# Required for: send-application-confirmation job, funding/renewal notifications
# Get these from: Zoho Mail Settings → Connected Accounts → App Passwords
# =============================================================================
ZOHO_SMTP_USER=
ZOHO_SMTP_PASS=

# =============================================================================
# Optional config
# =============================================================================
# ZOHO_TOKEN_STORE_PATH=        # default: ~/.zoho/tokens.json
# LOG_LEVEL=info                 # trace | debug | info | warn | error
# DRY_RUN=false                  # if true, write/delete ops are logged but skipped
